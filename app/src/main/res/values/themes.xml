<resources xmlns:tools="http://schemas.android.com/tools">
    <!-- Base application theme (Light Theme) -->
    <style name="Theme.Lalamove" parent="Theme.MaterialComponents.Light.NoActionBar">
        <!-- Primary brand color (orange) -->
        <item name="colorPrimary">#FF6B00</item>
        <item name="colorPrimaryVariant">#E65F00</item>
        <item name="colorOnPrimary">#FFFFFF</item>

        <!-- Secondary brand color -->
        <item name="colorSecondary">#FF6B00</item>
        <item name="colorSecondaryVariant">#E65F00</item>
        <item name="colorOnSecondary">#FFFFFF</item>

        <!-- Status bar color -->
        <item name="android:statusBarColor">#FFFFFF</item>
        <item name="android:windowLightStatusBar">true</item>

        <!-- Background color -->
        <item name="android:windowBackground">#FFFFFF</item>

        <!-- Screen transition animations for all activities -->
        <item name="android:windowAnimationStyle">@style/WindowAnimation</item>
    </style>

    <!-- Splash screen theme — white background, orange status bar text -->
    <style name="Theme.Lalamove.Splash" parent="Theme.Lalamove">
        <item name="android:statusBarColor">#FFFFFF</item>
        <item name="android:windowLightStatusBar">true</item>
        <item name="android:windowBackground">#FFFFFF</item>
    </style>

    <!-- Circle shape for ShapeableImageView -->
    <style name="CircleImageView" parent="">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSize">50%</item>
    </style>

    <!-- Slide-based transitions applied globally to every activity -->
    <style name="WindowAnimation" parent="@android:style/Animation.Activity">
        <item name="android:activityOpenEnterAnimation">@anim/slide_in_right</item>
        <item name="android:activityOpenExitAnimation">@anim/slide_out_left</item>
        <item name="android:activityCloseEnterAnimation">@anim/slide_in_left</item>
        <item name="android:activityCloseExitAnimation">@anim/slide_out_right</item>
    </style>
</resources>