<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Add Funds"
            android:textSize="18sp"
            android:textStyle="bold"
            android:textColor="#1A1A1A"
            android:gravity="center"
            android:layout_marginBottom="20dp" />

        <!-- Payment Method -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="PAYMENT METHOD"
            android:textSize="11sp"
            android:textStyle="bold"
            android:textColor="#888888"
            android:letterSpacing="0.05"
            android:layout_marginBottom="10dp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="20dp">

            <!-- GCash -->
            <LinearLayout
                android:id="@+id/cardGcash"
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="72dp"
                android:orientation="vertical"
                android:gravity="center"
                android:layout_marginEnd="8dp"
                android:background="@drawable/method_card_bg"
                android:padding="10dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="📱"
                    android:textSize="20sp"
                    android:layout_marginBottom="4dp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="GCash"
                    android:textSize="12sp"
                    android:textStyle="bold"
                    android:textColor="#1A1A1A" />
            </LinearLayout>

            <!-- Maya -->
            <LinearLayout
                android:id="@+id/cardMaya"
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="72dp"
                android:orientation="vertical"
                android:gravity="center"
                android:layout_marginEnd="8dp"
                android:background="@drawable/method_card_bg"
                android:padding="10dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="💚"
                    android:textSize="20sp"
                    android:layout_marginBottom="4dp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Maya"
                    android:textSize="12sp"
                    android:textStyle="bold"
                    android:textColor="#1A1A1A" />
            </LinearLayout>

            <!-- Visa -->
            <LinearLayout
                android:id="@+id/cardVisa"
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="72dp"
                android:orientation="vertical"
                android:gravity="center"
                android:background="@drawable/method_card_bg"
                android:padding="10dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="💳"
                    android:textSize="20sp"
                    android:layout_marginBottom="4dp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Visa / Card"
                    android:textSize="12sp"
                    android:textStyle="bold"
                    android:textColor="#1A1A1A" />
            </LinearLayout>

        </LinearLayout>

        <!-- Amount label -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="SELECT AMOUNT"
            android:textSize="11sp"
            android:textStyle="bold"
            android:textColor="#888888"
            android:letterSpacing="0.05"
            android:layout_marginBottom="10dp" />

        <!-- Preset amounts row 1 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="8dp">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/preset100"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="40dp"
                android:text="₱100"
                android:textSize="13sp"
                android:textStyle="bold"
                android:layout_marginEnd="6dp"
                app:strokeColor="#E0E0E0"
                app:cornerRadius="8dp"
                android:textColor="#555555" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/preset250"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="40dp"
                android:text="₱250"
                android:textSize="13sp"
                android:textStyle="bold"
                android:layout_marginEnd="6dp"
                app:strokeColor="#E0E0E0"
                app:cornerRadius="8dp"
                android:textColor="#555555" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/preset500"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="40dp"
                android:text="₱500"
                android:textSize="13sp"
                android:textStyle="bold"
                app:strokeColor="#E0E0E0"
                app:cornerRadius="8dp"
                android:textColor="#555555" />

        </LinearLayout>

        <!-- Preset amounts row 2 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="16dp">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/preset1000"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="40dp"
                android:text="₱1,000"
                android:textSize="13sp"
                android:textStyle="bold"
                android:layout_marginEnd="6dp"
                app:strokeColor="#E0E0E0"
                app:cornerRadius="8dp"
                android:textColor="#555555" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/preset2000"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="40dp"
                android:text="₱2,000"
                android:textSize="13sp"
                android:textStyle="bold"
                android:layout_marginEnd="6dp"
                app:strokeColor="#E0E0E0"
                app:cornerRadius="8dp"
                android:textColor="#555555" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/preset5000"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="40dp"
                android:text="₱5,000"
                android:textSize="13sp"
                android:textStyle="bold"
                app:strokeColor="#E0E0E0"
                app:cornerRadius="8dp"
                android:textColor="#555555" />

        </LinearLayout>

        <com.google.android.material.textfield.TextInputLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Custom amount (min ₱50)"
            style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
            android:layout_marginBottom="20dp"
            app:boxStrokeColor="#E0E0E0"
            app:hintTextColor="#888888">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/inputCustomAmount"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:inputType="numberDecimal"
                android:textSize="15sp"
                android:textColor="#1A1A1A" />

        </com.google.android.material.textfield.TextInputLayout>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnConfirmTopUp"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:text="Add Funds"
            android:textSize="15sp"
            android:textStyle="bold"
            android:textColor="#FFFFFF"
            app:cornerRadius="10dp"
            android:backgroundTint="#F15A22" />

    </LinearLayout>
</ScrollView>
