<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#FFFFFF"
    android:gravity="center"
    android:padding="32dp">

    <!-- Title -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Driver Found!"
        android:textColor="#1A1A1A"
        android:textSize="26sp"
        android:textStyle="bold"
        android:layout_marginBottom="20dp" />

    <!-- Driver profile photo (circle via ShapeableImageView) -->
    <com.google.android.material.imageview.ShapeableImageView
        android:id="@+id/imgDriverPhoto"
        android:layout_width="72dp"
        android:layout_height="72dp"
        android:layout_marginBottom="10dp"
        android:scaleType="centerCrop"
        app:shapeAppearanceOverlay="@style/CircleImageView"
        app:strokeWidth="2dp"
        app:strokeColor="#FF6B00" />

    <!-- Driver name -->
    <TextView
        android:id="@+id/textDriverName"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text=""
        android:textColor="#1A1A1A"
        android:textSize="17sp"
        android:textStyle="bold"
        android:layout_marginBottom="6dp" />

    <!-- Message -->
    <TextView
        android:id="@+id/textDriverFoundMessage"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Your driver has accepted the booking."
        android:textColor="#777777"
        android:textSize="14sp"
        android:lineSpacingExtra="4dp"
        android:gravity="center"
        android:layout_marginBottom="40dp" />

    <!-- Continue Button -->
    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnContinueToOrder"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:text="Continue"
        android:textColor="#FFFFFF"
        android:textStyle="bold"
        android:textSize="16sp"
        app:cornerRadius="14dp"
        android:backgroundTint="#FF6B00" />

</LinearLayout>
