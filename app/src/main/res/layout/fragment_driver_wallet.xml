<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#121212">

    <!-- Black Header -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="60dp"
        android:background="#1A1A1A"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingHorizontal="20dp"
        android:elevation="4dp">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Wallet"
            android:textColor="#FFFFFF"
            android:textSize="22sp"
            android:textStyle="bold" />
    </LinearLayout>

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <!-- Balance Card -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                app:cardCornerRadius="20dp"
                app:cardElevation="6dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="#1A1A1A"
                    android:orientation="vertical"
                    android:padding="28dp"
                    android:gravity="center">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Available Balance"
                        android:textColor="#AAAAAA"
                        android:textSize="13sp"
                        android:letterSpacing="0.08" />

                    <TextView
                        android:id="@+id/textWalletBalance"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="₱0.00"
                        android:textColor="#FF6B00"
                        android:textSize="40sp"
                        android:textStyle="bold"
                        android:layout_marginTop="6dp"
                        android:layout_marginBottom="20dp" />

                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal">

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btnTopUp"
                            android:layout_width="wrap_content"
                            android:layout_height="40dp"
                            android:text="Add Funds"
                            android:textColor="#1A1A1A"
                            android:backgroundTint="#FF6B00"
                            android:paddingHorizontal="24dp"
                            app:cornerRadius="20dp"
                            app:elevation="0dp"
                            android:layout_marginEnd="10dp" />

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btnWithdraw"
                            android:layout_width="wrap_content"
                            android:layout_height="40dp"
                            android:text="Withdraw"
                            android:textColor="#FF6B00"
                            android:backgroundTint="#2A2A2A"
                            android:paddingHorizontal="24dp"
                            app:cornerRadius="20dp"
                            app:elevation="0dp"
                            app:strokeColor="#FF6B00"
                            app:strokeWidth="1dp" />

                    </LinearLayout>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Filter Chips -->
            <HorizontalScrollView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:scrollbars="none"
                android:layout_marginBottom="14dp">

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">

                    <TextView
                        android:id="@+id/chipAll"
                        android:layout_width="wrap_content"
                        android:layout_height="36dp"
                        android:text="All"
                        android:textSize="13sp"
                        android:textStyle="bold"
                        android:textColor="#FFFFFF"
                        android:gravity="center"
                        android:paddingHorizontal="18dp"
                        android:background="@drawable/chip_active_bg"
                        android:layout_marginEnd="8dp"
                        android:clickable="true"
                        android:focusable="true" />

                    <TextView
                        android:id="@+id/chipEarnings"
                        android:layout_width="wrap_content"
                        android:layout_height="36dp"
                        android:text="Earnings"
                        android:textSize="13sp"
                        android:textStyle="bold"
                        android:textColor="#888888"
                        android:gravity="center"
                        android:paddingHorizontal="18dp"
                        android:background="@drawable/chip_inactive_bg"
                        android:layout_marginEnd="8dp"
                        android:clickable="true"
                        android:focusable="true" />

                    <TextView
                        android:id="@+id/chipFee"
                        android:layout_width="wrap_content"
                        android:layout_height="36dp"
                        android:text="Lalamove Fee"
                        android:textSize="13sp"
                        android:textStyle="bold"
                        android:textColor="#888888"
                        android:gravity="center"
                        android:paddingHorizontal="18dp"
                        android:background="@drawable/chip_inactive_bg"
                        android:layout_marginEnd="8dp"
                        android:clickable="true"
                        android:focusable="true" />

                    <TextView
                        android:id="@+id/chipWithdrawal"
                        android:layout_width="wrap_content"
                        android:layout_height="36dp"
                        android:text="Withdrawal"
                        android:textSize="13sp"
                        android:textStyle="bold"
                        android:textColor="#888888"
                        android:gravity="center"
                        android:paddingHorizontal="18dp"
                        android:background="@drawable/chip_inactive_bg"
                        android:clickable="true"
                        android:focusable="true" />

                </LinearLayout>
            </HorizontalScrollView>

            <!-- Transactions Card -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="16dp"
                app:cardElevation="2dp"
                app:cardBackgroundColor="#1E1E1E">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <!-- Section header (index 0 inside card) -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:paddingHorizontal="18dp"
                        android:paddingTop="16dp"
                        android:paddingBottom="12dp">

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="Recent Transactions"
                            android:textColor="#FFFFFF"
                            android:textSize="15sp"
                            android:textStyle="bold" />
                    </LinearLayout>

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:background="#2C2C2C" />

                    <!-- Empty state (always present; hidden when there are rows) -->
                    <TextView
                        android:id="@+id/textNoTransactions"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="No transactions yet"
                        android:textColor="#AAAAAA"
                        android:textSize="14sp"
                        android:gravity="center"
                        android:padding="32dp" />

                    <!-- Transaction rows injected here (index 3+) -->
                    <LinearLayout
                        android:id="@+id/layoutTransactions"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical" />

                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

</LinearLayout>
