<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#121212">

    <!-- Black Header -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="60dp"
        android:background="#1A1A1A"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingHorizontal="16dp"
        android:elevation="4dp">

        <!-- Online/Offline dropdown button (left) -->
        <LinearLayout
            android:id="@+id/btnStatusDropdown"
            android:layout_width="0dp"
            android:layout_weight="1"
            android:layout_height="36dp"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:background="@drawable/dropdown_bg"
            android:paddingHorizontal="12dp">

            <View
                android:id="@+id/statusDot"
                android:layout_width="9dp"
                android:layout_height="9dp"
                android:background="@drawable/pulse_circle"
                android:layout_marginEnd="8dp" />

            <TextView
                android:id="@+id/textStatusLabel"
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="wrap_content"
                android:text="Offline"
                android:textColor="#CCCCCC"
                android:textSize="13sp"
                android:textStyle="bold" />

            <ImageView
                android:layout_width="16dp"
                android:layout_height="16dp"
                android:src="@drawable/ic_arrow_right"
                android:rotation="90"
                app:tint="#888888" />
        </LinearLayout>

        <!-- Spacer -->
        <View android:layout_width="12dp" android:layout_height="1dp" />

        <!-- Bell icon -->
        <ImageView
            android:id="@+id/btnNotifications"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:src="@drawable/ic_bell"
            app:tint="#CCCCCC"
            android:padding="6dp" />

        <!-- Settings icon -->
        <ImageView
            android:id="@+id/btnSettings"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:src="@drawable/ic_settings"
            app:tint="#CCCCCC"
            android:padding="6dp"
            android:layout_marginStart="4dp" />

    </LinearLayout>

    <!-- Offline Overlay -->
    <LinearLayout
        android:id="@+id/offlineOverlay"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:gravity="center"
        android:padding="40dp">

        <ImageView
            android:layout_width="90dp"
            android:layout_height="90dp"
            android:src="@drawable/ic_box"
            app:tint="#DDDDDD"
            android:layout_marginBottom="20dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="You're Offline"
            android:textColor="#1A1A1A"
            android:textSize="22sp"
            android:textStyle="bold"
            android:layout_marginBottom="8dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Tap the status button to go online and start accepting orders."
            android:textColor="#888888"
            android:textSize="14sp"
            android:gravity="center" />
    </LinearLayout>

    <!-- Online Content -->
    <LinearLayout
        android:id="@+id/onlineContent"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:visibility="gone">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingHorizontal="16dp"
            android:paddingTop="16dp"
            android:paddingBottom="8dp">

            <TextView
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="wrap_content"
                android:text="Available Orders"
                android:textColor="#FFFFFF"
                android:textSize="17sp"
                android:textStyle="bold" />

            <View
                android:id="@+id/liveIndicator"
                android:layout_width="8dp"
                android:layout_height="8dp"
                android:background="@drawable/pulse_circle"
                android:layout_marginEnd="6dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="LIVE"
                android:textColor="#FF6B00"
                android:textSize="11sp"
                android:textStyle="bold" />
        </LinearLayout>

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/recyclerOrders"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:clipToPadding="false"
            android:paddingBottom="8dp" />

        <TextView
            android:id="@+id/textNoOrders"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="No pending orders right now.\nStand by..."
            android:textColor="#AAAAAA"
            android:textSize="14sp"
            android:gravity="center"
            android:padding="48dp"
            android:visibility="gone" />
    </LinearLayout>

</LinearLayout>
