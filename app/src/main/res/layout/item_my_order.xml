<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="16dp"
    android:layout_marginBottom="12dp"
    app:cardCornerRadius="12dp"
    app:cardElevation="2dp"
    app:strokeColor="#EEEEEE"
    app:strokeWidth="1dp"
    android:clickable="true"
    android:focusable="true"
    android:foreground="?attr/selectableItemBackground">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <!-- Status Badge + Fare -->
        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp">
            <TextView
                android:id="@+id/myOrderStatus"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="PENDING"
                android:textColor="#FF6B00"
                android:textSize="11sp"
                android:textStyle="bold"
                android:background="#FFF3E0"
                android:paddingHorizontal="10dp"
                android:paddingVertical="3dp" />
            <TextView
                android:id="@+id/myOrderFare"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="₱0.00"
                android:textColor="#222222"
                android:textSize="18sp"
                android:textStyle="bold"
                android:layout_alignParentEnd="true" />
        </RelativeLayout>

        <!-- Pickup -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="8dp"
            android:gravity="center_vertical">
            <View
                android:layout_width="10dp"
                android:layout_height="10dp"
                android:background="@drawable/pulse_circle"
                android:layout_marginEnd="12dp" />
            <TextView
                android:id="@+id/myOrderPickup"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Pickup"
                android:textColor="#444444"
                android:textSize="14sp"
                android:maxLines="1"
                android:ellipsize="end" />
        </LinearLayout>

        <!-- Dropoff -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="12dp"
            android:gravity="center_vertical">
            <ImageView
                android:layout_width="10dp"
                android:layout_height="10dp"
                android:src="@drawable/ic_location_orange"
                android:scaleType="fitCenter"
                android:layout_marginEnd="12dp" />
            <TextView
                android:id="@+id/myOrderDropoff"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Dropoff"
                android:textColor="#444444"
                android:textSize="14sp"
                android:maxLines="1"
                android:ellipsize="end" />
        </LinearLayout>

        <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#EEEEEE" android:layout_marginVertical="8dp" />

        <!-- Driver Info (Hidden by default) -->
        <LinearLayout
            android:id="@+id/myOrderDriverSection"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="12dp"
            android:background="#FAFAFA"
            android:padding="8dp"
            android:visibility="gone">
            <ImageView
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:src="@drawable/ic_profile_placeholder"
                android:scaleType="centerCrop"
                android:layout_marginEnd="8dp" />
            <TextView
                android:id="@+id/myOrderDriverText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Driver has accepted your booking."
                android:textColor="#444444"
                android:textSize="12sp" />
        </LinearLayout>

        <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#EEEEEE" />

        <!-- Action button row -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginTop="10dp">
            <ImageView
                android:layout_width="16dp"
                android:layout_height="16dp"
                android:src="@drawable/ic_box"
                app:tint="#888888"
                android:layout_marginEnd="6dp" />
            <TextView
                android:id="@+id/myOrderVehicle"
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="wrap_content"
                android:text="Motorcycle"
                android:textColor="#888888"
                android:textSize="12sp" />
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnOrderAction"
                android:layout_width="wrap_content"
                android:layout_height="36dp"
                android:text="View"
                android:textColor="#FF6B00"
                android:textSize="12sp"
                style="@style/Widget.MaterialComponents.Button.TextButton"
                android:visibility="gone" />
        </LinearLayout>

        <!-- Secondary actions: Reorder / Report / Favourite -->
        <LinearLayout
            android:id="@+id/secondaryActionsRow"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="6dp"
            android:visibility="gone">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnReorder"
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="34dp"
                android:text="Reorder"
                android:textSize="11sp"
                android:textColor="#FF6B00"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                app:strokeColor="#FF6B00"
                android:layout_marginEnd="4dp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnReportDriver"
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="34dp"
                android:text="Report"
                android:textSize="11sp"
                android:textColor="#E53935"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                app:strokeColor="#E53935"
                android:layout_marginEnd="4dp"
                android:visibility="gone" />

            <ImageView
                android:id="@+id/btnFavDriver"
                android:layout_width="34dp"
                android:layout_height="34dp"
                android:src="@drawable/ic_star"
                android:padding="4dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:clickable="true"
                android:focusable="true"
                android:visibility="gone" />

        </LinearLayout>
    </LinearLayout>
</com.google.android.material.card.MaterialCardView>
