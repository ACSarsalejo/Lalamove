<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical">

    <!-- Map area with floating overlays -->
    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <org.osmdroid.views.MapView
            android:id="@+id/addrMapView"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:clickable="true" />

        <!-- Center crosshair pin (static overlay) -->
        <ImageView
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:src="@drawable/ic_map_pin_center"
            android:layout_gravity="center"
            android:elevation="2dp" />

        <!-- Floating address pill at top -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_gravity="top|center_horizontal"
            android:layout_margin="12dp"
            app:cardCornerRadius="30dp"
            app:cardElevation="6dp"
            app:cardBackgroundColor="#FFFFFF"
            android:elevation="4dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingStart="16dp"
                android:paddingEnd="16dp">

                <ImageView
                    android:id="@+id/addrBackButton"
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:src="@drawable/ic_back"
                    app:tint="#333333"
                    android:clickable="true"
                    android:focusable="true" />

                <View
                    android:layout_width="10dp"
                    android:layout_height="10dp"
                    android:background="@drawable/shape_pickup_dot"
                    android:layout_marginStart="14dp"
                    android:layout_marginEnd="12dp" />

                <TextView
                    android:id="@+id/addrLocationName"
                    android:layout_width="0dp"
                    android:layout_weight="1"
                    android:layout_height="wrap_content"
                    android:text="Selected location"
                    android:textColor="#1A1A1A"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:maxLines="1"
                    android:ellipsize="end" />

                <ImageView
                    android:id="@+id/addrEditButton"
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:src="@drawable/ic_note"
                    app:tint="#888888"
                    android:clickable="true"
                    android:focusable="true"
                    android:layout_marginStart="10dp" />

            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

    </FrameLayout>

    <!-- Bottom: Address details form -->
    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="#FFFFFF"
        android:elevation="8dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingHorizontal="24dp"
            android:paddingTop="24dp"
            android:paddingBottom="32dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Address details"
                android:textSize="22sp"
                android:textStyle="bold"
                android:textColor="#1A1A1A"
                android:layout_marginBottom="20dp" />

            <!-- Mobile number -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:background="@drawable/input_border"
                android:layout_marginBottom="14dp"
                android:paddingHorizontal="14dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="+63"
                    android:textColor="#888888"
                    android:textSize="15sp"
                    android:layout_marginEnd="10dp" />

                <View
                    android:layout_width="1dp"
                    android:layout_height="24dp"
                    android:background="#DDDDDD"
                    android:layout_marginEnd="10dp" />

                <EditText
                    android:id="@+id/inputMobile"
                    android:layout_width="0dp"
                    android:layout_weight="1"
                    android:layout_height="match_parent"
                    android:background="@null"
                    android:hint="Mobile number"
                    android:textColor="#1A1A1A"
                    android:textColorHint="#AAAAAA"
                    android:textSize="15sp"
                    android:inputType="phone"
                    android:maxLines="1" />

            </LinearLayout>

            <!-- Contact name -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:background="@drawable/input_border"
                android:layout_marginBottom="20dp"
                android:paddingHorizontal="14dp">

                <EditText
                    android:id="@+id/inputContactName"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:background="@null"
                    android:hint="Contact name"
                    android:textColor="#1A1A1A"
                    android:textColorHint="#AAAAAA"
                    android:textSize="15sp"
                    android:inputType="textPersonName|textCapWords"
                    android:maxLines="1" />

            </LinearLayout>

            <!-- Save this address -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="24dp">

                <CheckBox
                    android:id="@+id/checkSaveAddress"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:buttonTint="#FF6B00" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Save this address"
                    android:textColor="#444444"
                    android:textSize="15sp"
                    android:layout_marginStart="8dp" />

            </LinearLayout>

            <!-- Confirm -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnConfirmAddress"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:text="Confirm"
                android:textColor="#FFFFFF"
                android:textStyle="bold"
                android:textSize="16sp"
                app:cornerRadius="12dp"
                android:backgroundTint="#FF6B00" />

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

</LinearLayout>
