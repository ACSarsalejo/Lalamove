<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FFFFFF">

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toTopOf="@id/bottomBar">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="20dp">

            <!-- TYPES OF DELIVERY ITEMS -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="TYPES OF DELIVERY ITEMS"
                android:textColor="#A0A0A0"
                android:textSize="12sp"
                android:textStyle="bold"
                android:letterSpacing="0.05"
                android:layout_marginBottom="12dp" />

            <GridLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:columnCount="2"
                android:useDefaultMargins="false">

                <CheckBox android:id="@+id/cbFood" android:layout_width="0dp" android:layout_columnWeight="1" android:layout_height="wrap_content" android:text="Food &amp; Beverages" android:textSize="14sp" android:textColor="#444444" android:buttonTint="#CCCCCC" />
                <CheckBox android:id="@+id/cbAppliances" android:layout_width="0dp" android:layout_columnWeight="1" android:layout_height="wrap_content" android:text="Appliances / Furniture" android:textSize="14sp" android:textColor="#444444" android:buttonTint="#CCCCCC" />
                <CheckBox android:id="@+id/cbOffice" android:layout_width="0dp" android:layout_columnWeight="1" android:layout_height="wrap_content" android:text="Office items /\nDocuments" android:textSize="14sp" android:textColor="#444444" android:buttonTint="#CCCCCC" />
                <CheckBox android:id="@+id/cbConstruction" android:layout_width="0dp" android:layout_columnWeight="1" android:layout_height="wrap_content" android:text="Construction materials" android:textSize="14sp" android:textColor="#444444" android:buttonTint="#CCCCCC" />
                <CheckBox android:id="@+id/cbClothing" android:layout_width="0dp" android:layout_columnWeight="1" android:layout_height="wrap_content" android:text="Clothing &amp; Accessories" android:textSize="14sp" android:textColor="#444444" android:buttonTint="#CCCCCC" />
                <CheckBox android:id="@+id/cbElectronics" android:layout_width="0dp" android:layout_columnWeight="1" android:layout_height="wrap_content" android:text="Electronics and gadgets" android:textSize="14sp" android:textColor="#444444" android:buttonTint="#CCCCCC" />
                <CheckBox android:id="@+id/cbOthers" android:layout_width="0dp" android:layout_columnWeight="1" android:layout_height="wrap_content" android:text="Others" android:textSize="14sp" android:textColor="#444444" android:buttonTint="#CCCCCC" />
            </GridLayout>

            <!-- ITEM NAME -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="ITEM NAME"
                android:textColor="#A0A0A0"
                android:textSize="12sp"
                android:textStyle="bold"
                android:letterSpacing="0.05"
                android:layout_marginTop="24dp"
                android:layout_marginBottom="8dp" />

            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="8dp"
                app:cardElevation="0dp"
                app:strokeColor="#DDDDDD"
                app:strokeWidth="1dp">
                <EditText
                    android:id="@+id/inputItemName"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="@null"
                    android:padding="16dp"
                    android:hint="E.g. Office Desk, 2 Boxes of Books..."
                    android:textColorHint="#AAAAAA"
                    android:textSize="14sp"
                    android:textColor="#222222" />
            </com.google.android.material.card.MaterialCardView>

            <!-- NUMBER OF PACKAGES -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="NUMBER OF PACKAGES"
                android:textColor="#A0A0A0"
                android:textSize="12sp"
                android:textStyle="bold"
                android:letterSpacing="0.05"
                android:layout_marginTop="24dp"
                android:layout_marginBottom="8dp" />

            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="8dp"
                app:cardElevation="0dp"
                app:strokeColor="#DDDDDD"
                app:strokeWidth="1dp">
                <RelativeLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:padding="16dp">
                    <TextView
                        android:id="@+id/textPackageCount"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="0"
                        android:textColor="#222222"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        android:layout_centerVertical="true" />
                    
                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:layout_alignParentEnd="true"
                        android:layout_centerVertical="true">
                        <ImageView
                            android:id="@+id/btnMinus"
                            android:layout_width="24dp"
                            android:layout_height="24dp"
                            android:src="@drawable/ic_remove"
                            app:tint="#888888"
                            android:padding="4dp" />
                        <ImageView
                            android:id="@+id/btnPlus"
                            android:layout_width="24dp"
                            android:layout_height="24dp"
                            android:src="@drawable/ic_add"
                            app:tint="#888888"
                            android:padding="4dp"
                            android:layout_marginStart="16dp" />
                    </LinearLayout>
                </RelativeLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- TOTAL SIZE -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="TOTAL SIZE"
                android:textColor="#A0A0A0"
                android:textSize="12sp"
                android:textStyle="bold"
                android:letterSpacing="0.05"
                android:layout_marginTop="24dp"
                android:layout_marginBottom="8dp" />

            <com.google.android.material.textfield.TextInputLayout
                style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox.ExposedDropdownMenu"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:boxStrokeColor="#DDDDDD"
                app:boxCornerRadiusTopStart="8dp"
                app:boxCornerRadiusTopEnd="8dp"
                app:boxCornerRadiusBottomStart="8dp"
                app:boxCornerRadiusBottomEnd="8dp">

                <AutoCompleteTextView
                    android:id="@+id/dropdownSize"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:inputType="none"
                    android:padding="16dp"
                    android:text="Select size"
                    android:textColor="#222222"
                    android:textSize="14sp" />
            </com.google.android.material.textfield.TextInputLayout>

            <!-- TOTAL WEIGHT -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="TOTAL WEIGHT"
                android:textColor="#A0A0A0"
                android:textSize="12sp"
                android:textStyle="bold"
                android:letterSpacing="0.05"
                android:layout_marginTop="24dp"
                android:layout_marginBottom="8dp" />

            <com.google.android.material.textfield.TextInputLayout
                style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox.ExposedDropdownMenu"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:boxStrokeColor="#DDDDDD"
                app:boxCornerRadiusTopStart="8dp"
                app:boxCornerRadiusTopEnd="8dp"
                app:boxCornerRadiusBottomStart="8dp"
                app:boxCornerRadiusBottomEnd="8dp">

                <AutoCompleteTextView
                    android:id="@+id/dropdownWeight"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:inputType="none"
                    android:padding="16dp"
                    android:text="Select weight (kg)"
                    android:textColor="#222222"
                    android:textSize="14sp" />
            </com.google.android.material.textfield.TextInputLayout>

            <!-- HANDLING INSTRUCTIONS -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="HANDLING INSTRUCTIONS"
                android:textColor="#A0A0A0"
                android:textSize="12sp"
                android:textStyle="bold"
                android:letterSpacing="0.05"
                android:layout_marginTop="24dp"
                android:layout_marginBottom="12dp" />

            <GridLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:columnCount="2"
                android:useDefaultMargins="false">

                <CheckBox android:id="@+id/cbNoHandling" android:layout_width="0dp" android:layout_columnWeight="1" android:layout_height="wrap_content" android:text="No special handling" android:textSize="14sp" android:textColor="#444444" android:buttonTint="#CCCCCC" />
                <CheckBox android:id="@+id/cbFragile" android:layout_width="0dp" android:layout_columnWeight="1" android:layout_height="wrap_content" android:text="Fragile" android:textSize="14sp" android:textColor="#444444" android:buttonTint="#CCCCCC" />
                <CheckBox android:id="@+id/cbPerishable" android:layout_width="0dp" android:layout_columnWeight="1" android:layout_height="wrap_content" android:text="Perishable" android:textSize="14sp" android:textColor="#444444" android:buttonTint="#CCCCCC" />
                <CheckBox android:id="@+id/cbTemperature" android:layout_width="0dp" android:layout_columnWeight="1" android:layout_height="wrap_content" android:text="Temperature sensitive" android:textSize="14sp" android:textColor="#444444" android:buttonTint="#CCCCCC" />
                <CheckBox android:id="@+id/cbKeepDry" android:layout_width="0dp" android:layout_columnWeight="1" android:layout_height="wrap_content" android:text="Keep dry" android:textSize="14sp" android:textColor="#444444" android:buttonTint="#CCCCCC" />
            </GridLayout>

            <!-- ITEM PHOTO -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="ITEM PHOTO"
                android:textColor="#A0A0A0"
                android:textSize="12sp"
                android:textStyle="bold"
                android:letterSpacing="0.05"
                android:layout_marginTop="24dp"
                android:layout_marginBottom="8dp" />

            <com.google.android.material.card.MaterialCardView
                android:id="@+id/btnChoosePhoto"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="8dp"
                app:cardElevation="0dp"
                app:strokeColor="#DDDDDD"
                app:strokeWidth="1dp"
                android:layout_marginBottom="32dp">
                
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="12dp"
                    android:gravity="center">
                    
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical">
                        
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Choose File"
                            android:textColor="#222222"
                            android:textSize="14sp"
                            android:background="@drawable/bg_choose_file"
                            android:paddingHorizontal="12dp"
                            android:paddingVertical="6dp" />
                            
                        <TextView
                            android:id="@+id/textFileName"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="No file chosen"
                            android:textColor="#666666"
                            android:textSize="14sp"
                            android:layout_marginStart="12dp"
                            android:ellipsize="end"
                            android:maxLines="1" />
                    </LinearLayout>
                    
                    <ImageView
                        android:id="@+id/imagePhotoPreview"
                        android:layout_width="match_parent"
                        android:layout_height="200dp"
                        android:layout_marginTop="12dp"
                        android:scaleType="centerCrop"
                        android:visibility="gone" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

        </LinearLayout>
    </ScrollView>

    <!-- Bottom Action Bar -->
    <LinearLayout
        android:id="@+id/bottomBar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        app:layout_constraintBottom_toBottomOf="parent"
        android:padding="16dp"
        android:gravity="end"
        android:background="#FFFFFF"
        android:elevation="8dp">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnCancel"
            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Cancel"
            android:textColor="#222222"
            app:strokeColor="#DDDDDD"
            android:layout_marginEnd="12dp" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnSaveItemDetails"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Save"
            android:textColor="#AAAAAA"
            app:backgroundTint="#EEEEEE"
            app:elevation="0dp" />

    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
